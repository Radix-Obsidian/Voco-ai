# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Cognitive Engine WebSocket URL
# Development: ws://localhost:8001/ws/voco-stream
# Production: wss://api.itsvoco.com/ws/voco-stream
# Use .env (dev) or .env.production (prod) to override
VITE_COGNITIVE_ENGINE_WS=ws://localhost:8001/ws/voco-stream

# License validation (Keygen.sh) — leave blank to disable for development
KEYGEN_ACCOUNT_ID=
